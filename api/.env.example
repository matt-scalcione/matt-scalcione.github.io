ESPORTS_DATA_MODE=hybrid
PROVIDER_CACHE_MS=30000
PROVIDER_TIMEOUT_MS=15000
DOTA_TIERS=1,2,3,4
CANONICAL_STORE_ENABLED=0
CANONICAL_STORE_SCHEMA=pulseboard
CANONICAL_STORE_SNAPSHOT_HISTORY_ENABLED=0
CANONICAL_STORE_COMPACT_ON_INIT=1
CANONICAL_STORE_RETENTION_DAYS=3
CANONICAL_PREWARM_MATCH_LIMIT=2
CANONICAL_PREWARM_TEAM_LIMIT=2
DATABASE_URL=

# Liquipedia schedule ingestion (API only)
LIQUIPEDIA_DOTA_API_URL=https://liquipedia.net/dota2/api.php?action=parse&page=Liquipedia:Matches&prop=text&formatversion=2&format=json
LIQUIPEDIA_DOTA_API_CACHE_MS=30000

# STRATZ live-provider activation
STRATZ_GRAPHQL_URL=https://api.stratz.com/graphql
STRATZ_API_TOKEN=

# Bundled default STRATZ queries are used automatically.
# Optional overrides for local debugging only:
STRATZ_DOTA_LIVE_QUERY=
STRATZ_DOTA_MATCH_DETAIL_QUERY=

STRATZ_DOTA_LIVE_QUERY_FILE=
STRATZ_DOTA_MATCH_DETAIL_QUERY_FILE=
