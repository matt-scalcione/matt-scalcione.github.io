{
  "name": "pulseboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "npm run build:pages",
    "build:pages": "node scripts/build-pages-artifact.mjs",
    "seo:sitemap": "node scripts/generate-sitemap.mjs",
    "seo:check": "node scripts/seo-check.mjs",
    "providers:snapshot:dota": "node scripts/generate-dota-schedule-snapshot.mjs",
    "logos:check": "node scripts/check-team-logo-coverage.mjs",
    "logos:backfill": "node scripts/backfill-team-logos.mjs",
    "heroes:dota:sync": "node scripts/sync-dota-heroes.mjs",
    "logos:fallback": "node scripts/fallback-team-logos.mjs",
    "logos:optimize": "node scripts/optimize-team-logos.mjs",
    "logos:sync": "node scripts/sync-team-logos.mjs",
    "providers:check": "npm run providers:check --prefix api",
    "test:api": "npm test --prefix api",
    "verify:site": "node scripts/verify-site.mjs",
    "verify": "npm run verify:site && npm run test:api"
  }
